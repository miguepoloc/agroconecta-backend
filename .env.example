# Base de datos (Neon en producción, PostgreSQL local en desarrollo)
DATABASE_URL=postgresql+asyncpg://agroconecta:agroconecta@localhost:5432/agroconecta
DATABASE_URL_TEST=postgresql+asyncpg://agroconecta_test:agroconecta_test@localhost:5433/agroconecta_test

# JWT
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# Descomentar para usar LocalStack local (ENVIRONMENT=staging):
#AWS_ENDPOINT_URL=http://localhost:4566

# S3
S3_BUCKET_PRODUCTS=agroconecta-products

# SES / EventBridge
SES_SENDER_EMAIL=noreply@agroconecta.co
EVENTBRIDGE_BUS_NAME=agroconecta-events

# DynamoDB — nombres de tablas
# Con ENVIRONMENT=development se usan stubs en memoria (no necesita DynamoDB real)
# Con ENVIRONMENT=staging/production apunta a LocalStack o AWS
DYNAMO_REFRESH_TOKENS_TABLE=agroconecta-refresh-tokens
DYNAMO_RATE_LIMITS_TABLE=agroconecta-rate-limits
DYNAMO_EVENTS_LOG_TABLE=agroconecta-events-log

# App
# development → stubs en memoria (sin AWS, sin LocalStack)
# staging     → LocalStack en localhost:4566
# production  → AWS real (Lambda usa Secrets Manager para DATABASE_URL)
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
